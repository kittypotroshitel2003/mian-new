DEPLOY_HOST=YOUR_SERVER_IP
DEPLOY_PORT=22
DEPLOY_USER=deploy
# Рекомендуется: SSH-ключ вместо пароля
# Сгенерировать ключ: ssh-keygen -t ed25519 -f ~/.ssh/mian_deploy
# Скопировать на сервер: ssh-copy-id -i ~/.ssh/mian_deploy.pub deploy@YOUR_SERVER_IP
DEPLOY_KEY_PATH=~/.ssh/mian_deploy

# URL сайта для SEO (sitemap, robots, og:url)
NEXT_PUBLIC_SITE_URL=https://your-domain.ru
